{
  "SteamInputBridge": {
    "Logging": {
      "LogDirectory": "./logs",
      "Level": "Information"
    },
    "Steam": {
      "SrmExportPath": "./srm/manifest.json"
    },
    "Shortcuts": [
      {
        "Name": "motion-on",
        "Keys": "Num0",
        "Target": "Motion",
        "Value": "HoldEnabled"
      },
      {
        "Name": "motion-off",
        "Keys": "Num1",
        "Target": "Motion",
        "Value": "HoldDisabled"
      },
      {
        "Name": "motion-toggle",
        "Keys": "Num2",
        "Target": "Motion",
        "Value": "Toggle"
      },
      {
        "Name": "pointer-on",
        "Keys": "Num0",
        "Target": "Pointer",
        "Value": "HoldEnabled"
      },
      {
        "Name": "pointer-off",
        "Keys": "Num1",
        "Target": "Pointer",
        "Value": "HoldDisabled"
      },
      {
        "Name": "pointer-toggle",
        "Keys": "Num2",
        "Target": "Pointer",
        "Value": "Toggle"
      }
    ],
    "Games": {
      // ======================================================================
      // Riot Games
      // ======================================================================
      "2xko": {
        "Title": "2XKO",
        "Executable": "C:/Riot Games/Riot Client/RiotClientServices.exe",
        "Arguments": "--launch-product=lion --launch-patchline=live",
        "ControllerOutput": "Xbox360",
        "ReceiverProcesses": [
          "Lion-Win64-Shipping.exe"
        ]
      },
      "lol": {
        "Title": "League of Legends",
        "Executable": "C:/Riot Games/Riot Client/RiotClientServices.exe",
        "Arguments": "--launch-product=league_of_legends --launch-patchline=live",
        "ReceiverProcesses": [
          "League of Legends.exe"
        ]
      },
      "valorant": {
        "Title": "Valorant",
        "Executable": "C:/Riot Games/Riot Client/RiotClientServices.exe",
        "Arguments": "--launch-product=valorant --launch-patchline=live",
        "MouseOutput": "Viiper",
        "ReceiverProcesses": [
          "VALORANT-Win64-Shipping.exe"
        ]
      },
      // ======================================================================
      // Blizzard Entertainment
      // ======================================================================
      "hots": {
        "Title": "Heroes of the Storm",
        "Executable": "C:/Program Files (x86)/Battle.net/Battle.net.exe",
        "Arguments": "--exec=\"launch Hero\"",
        "WorkingDirectory": "C:/Program Files (x86)/Battle.net",
        "ReceiverProcesses": [
          "Heroes of the Storm.exe"
        ]
      },
      "overwatch": {
        "Title": "Overwatch",
        "Executable": "C:/Program Files (x86)/Battle.net/Battle.net.exe",
        "Arguments": "--exec=\"launch Pro\"",
        "WorkingDirectory": "C:/Program Files (x86)/Battle.net",
        "ControllerOutput": "Xbox360",
        "MouseOutput": "Viiper",
        "ReceiverProcesses": [
          "Overwatch.exe"
        ]
      },
      "wow": {
        "Title": "World of Warcraft",
        "Executable": "C:/Program Files (x86)/Battle.net/Battle.net.exe",
        "Arguments": "--exec=\"launch WoW\"",
        "WorkingDirectory": "C:/Program Files (x86)/Battle.net",
        "ReceiverProcesses": [
          "Wow.exe"
        ]
      }
    }
  }
}
