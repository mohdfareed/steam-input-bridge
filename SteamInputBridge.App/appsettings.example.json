{
  "SteamInputBridge": {
    "Logging": {
      "LogDirectory": "./logs",
      "Level": "Debug"
    },
    "Viiper": {
      "Host": "host.docker.internal",
      "Port": 3242
    },
    "Teensy": {
      "Port": "COM3",
      "FirmwareDirectory": "./Firmware"
    },
    "Steam": {
      "SrmExportPath": "./srm-manifest.json"
    },
    "Shortcuts": [
      {
        "Keys": "Ctrl+Alt+F1",
        "Target": "#808080"
      },
      {
        "Keys": "Ctrl+Alt+F1",
        "Target": "MousePointer",
        "Action": "Disable"
      },
      {
        "Keys": "Ctrl+Alt+F2",
        "Target": "Microphone",
        "Action": "Toggle"
      }
    ],
    "Games": {
      "game-id": {
        "Title": "Game Title",
        "Executable": "C:/Path/To/GameExecutable.exe",
        "Arguments": "--game-arguments",
        "SteamAppId": 123456,
        "WorkingDirectory": "C:/Path/To",
        "MouseInput": "Steam",
        "MouseOutput": "Viiper",
        "ControllerOutput": "Xbox360",
        "ReceiverProcesses": [
          "GameProcess.exe",
          "SubGameProcess.exe"
        ]
      }
    }
  }
}
