{
  "SteamInputBridge": {
    "Logging": {
      "LogDirectory": "./logs",
      "Level": "Debug"
    },
    "Steam": {
      "SrmExportPath": "./srm/manifest.json"
    },
    "Shortcuts": [
      {
        "Keys": "Num.",
        "Targets": [
          "Microphone"
        ],
        "Value": "HoldEnabled"
      },
      {
        "Keys": "Ctrl+Num.",
        "Targets": [
          "Microphone"
        ],
        "Value": "Toggle"
      },
      // ======================================================================
      // MARK: Indicators
      // ======================================================================
      {
        "Keys": "Num0",
        "Targets": [
          "#FFFFFF" // White
        ],
        "Value": "HoldEnabled"
      },
      {
        "Keys": "Num1",
        "Targets": [
          "#FF0000" // Red
        ],
        "Value": "HoldEnabled"
      },
      {
        "Keys": "Num2",
        "Targets": [
          "#00FF00" // Green
        ],
        "Value": "HoldEnabled"
      },
      {
        "Keys": "Num3",
        "Targets": [
          "#FFFF00" // Yellow
        ],
        "Value": "HoldEnabled"
      },
      {
        "Keys": "Num4",
        "Targets": [
          "#0000FF" // Blue
        ],
        "Value": "HoldEnabled"
      },
      {
        "Keys": "Num5",
        "Targets": [
          "#FF00FF" // Magenta
        ],
        "Value": "HoldEnabled"
      },
      {
        "Keys": "Num6",
        "Targets": [
          "#00FFFF" // Cyan
        ],
        "Value": "HoldEnabled"
      },
      // ======================================================================
      // MARK: Motion
      // ======================================================================
      {
        "Keys": "Num7",
        "Targets": [
          "ControllerMotion",
          "MousePointer"
        ],
        "Value": "HoldEnabled"
      },
      {
        "Keys": "Num8",
        "Targets": [
          "ControllerMotion",
          "MousePointer"
        ],
        "Value": "HoldDisabled"
      },
      {
        "Keys": "Num9",
        "Targets": [
          "ControllerMotion",
          "MousePointer"
        ],
        "Value": "Toggle"
      }
    ],
    "Games": {
      "test": {
        "Title": "Testing",
        "Executable": "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe",
        "ControllerOutput": "DS4",
        "MouseOutput": "Viiper",
        "ReceiverProcesses": [
          "Discovery.exe",
          "FragPunk.exe",
          "steamwebhelper.exe",
          "msedge.exe"
        ]
      },
      // ======================================================================
      // MARK: Riot
      // ======================================================================
      "2xko": {
        "Title": "2XKO",
        "Executable": "C:/Riot Games/Riot Client/RiotClientServices.exe",
        "Arguments": "--launch-product=lion --launch-patchline=live",
        "ControllerOutput": "DS4",
        "ReceiverProcesses": [
          "Lion-Win64-Shipping.exe"
        ]
      },
      "lol": {
        "Title": "League of Legends",
        "Executable": "C:/Riot Games/Riot Client/RiotClientServices.exe",
        "Arguments": "--launch-product=league_of_legends --launch-patchline=live",
        "ReceiverProcesses": [
          "League of Legends.exe"
        ]
      },
      "valorant": {
        "Title": "Valorant",
        "Executable": "C:/Riot Games/Riot Client/RiotClientServices.exe",
        "Arguments": "--launch-product=valorant --launch-patchline=live",
        "MouseOutput": "Viiper",
        "ReceiverProcesses": [
          "VALORANT-Win64-Shipping.exe"
        ]
      },
      // ======================================================================
      // MARK: Blizzard
      // ======================================================================
      "hots": {
        "Title": "Heroes of the Storm",
        "Executable": "C:/Program Files (x86)/Battle.net/Battle.net.exe",
        "Arguments": "--exec=\"launch Hero\"",
        "WorkingDirectory": "C:/Program Files (x86)/Battle.net",
        "ReceiverProcesses": [
          "Heroes of the Storm.exe"
        ]
      },
      "wow": {
        "Title": "World of Warcraft",
        "Executable": "C:/Program Files (x86)/Battle.net/Battle.net.exe",
        "Arguments": "--exec=\"launch WoW\"",
        "WorkingDirectory": "C:/Program Files (x86)/Battle.net",
        "ReceiverProcesses": [
          "Wow.exe"
        ]
      }
    }
  }
}
